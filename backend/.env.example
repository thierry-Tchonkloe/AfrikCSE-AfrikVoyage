# ─── Serveur ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://postgres:root@localhost:5432/afrikcse-afrikvoyage_db?schema=public"

# ─── Auth JWT ──────────────────────────────────────────
# Un seul secret signataire pour les access tokens (24h) ET les refresh tokens (90d).
# Générer : openssl rand -hex 64
JWT_SECRET=

# Secret court pour le cookie `session` Next.js (doit être identique côté frontend)
# Générer : openssl rand -base64 32
SESSION_COOKIE_SECRET=

# ─── CORS ──────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── Chiffrement & Tickets ─────────────────────────────
# AES-256-GCM — chiffrement des clés API partenaires stockées en BDD (V2)
# Doit faire 32 bytes / 64 caractères hex. Générer : openssl rand -hex 32
ENCRYPTION_KEY=

# HMAC-SHA256 — signature des QR codes tickets (V2)
# Doit faire 32 bytes / 64 caractères hex. Générer : openssl rand -hex 32
TICKET_SECRET=

# ─── Cloudinary (uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Amadeus (recherche de vols) ───────────────────────
# Conservé comme fallback si la config Amadeus n'est pas définie en BDD (ApiIntegration).
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
AMADEUS_BASE_URL="https://test.api.amadeus.com"

# ─── Email (Resend) ─────────────────────────────────────
# ⚠️  En sandbox Resend, les emails ne peuvent être envoyés QU'à l'adresse du compte Resend.
#     Pour envoyer à tous les destinataires :
#     1. Ajouter et vérifier le domaine sur https://resend.com/domains
#     2. Remplacer EMAIL_FROM par noreply@<votre-domaine>
RESEND_API_KEY=""
EMAIL_FROM=""
MAIL_FROM_NAME="AfrikCSE & AfrikVoyage"
SUPPORT_EMAIL=""
SUPER_ADMIN_NOTIFICATION_EMAIL=""

# ─── Paiements ─────────────────────────────────────────
KKIAPAY_PUBLIC_KEY=pk_live_...
KKIAPAY_PRIVATE_KEY=pv_live_...
KKIAPAY_SECRET_KEY=sk_live_...
FEDAPAY_SECRET_KEY=sk_live_...
FEDAPAY_WEBHOOK_TOKEN=
# URL publique du backend (pour les webhooks FedaPay/KkiaPay)
BACKEND_URL=https://ton-backend.railway.app

# ─── OCR (V2 — scan reçus notes de frais) ─────────────
# Fournisseur OCR. Valeurs possibles : mindee | google-vision
OCR_PROVIDER=mindee
OCR_API_KEY=
# Si Mindee : type de document à extraire
MINDEE_DOCUMENT_TYPE=receipt

# ─── PDF (V2 — carte de membre numérique) ─────────────
# Chemin vers Chromium si génération PDF via Puppeteer
# Laisser vide pour utiliser pdfkit (sans dépendance Chromium)
PUPPETEER_EXECUTABLE_PATH=
