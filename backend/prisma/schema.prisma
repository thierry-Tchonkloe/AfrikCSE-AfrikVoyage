}

// ─── TICKET QR (V2 Sprint 2) ──────────────────────────────

enum TicketStatus {
  VALID
  USED
  EXPIRED
  CANCELLED
}

model Ticket {
  id              String            @id @default(cuid())
  code            String            @unique
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  offerId         String
  offer           BenefitCatalogItem @relation(fields: [offerId], references: [id])
  userId          String
  user            User              @relation(fields: [userId], references: [id])
