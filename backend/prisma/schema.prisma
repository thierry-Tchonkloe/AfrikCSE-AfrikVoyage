// ─── TRAVEL POLICY (V2 Sprint 3) ─────────────────────────

model TravelPolicy {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id])
  name                   String
  description            String?
  isDefault              Boolean      @default(false)
  isActive               Boolean      @default(true)
  maxFlightBudget        Decimal?     @db.Decimal(10,2)
  maxHotelBudgetPerNight Decimal?     @db.Decimal(10,2)
  maxDailyAllowance      Decimal?     @db.Decimal(10,2)
