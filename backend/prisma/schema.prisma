// ─── FAQ ENTRY (V2 Sprint 4) ──────────────────────────────

enum FaqStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FaqEntry {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  question       String
  answer         String
  category       String?
  order          Int       @default(0)
  status         FaqStatus @default(DRAFT)
  createdById    String
  createdBy      User      @relation("FaqEntryAuthor", fields: [createdById], references: [id])
