generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String     @id @default(uuid())
  name          String
  email         String?    @unique
  slug          String     @unique
  status        OrgStatus  @default(PENDING)
  hasVoyage     Boolean    @default(false)
  hasCSE        Boolean    @default(false)
  isHost        Boolean    @default(false) // True pour l'entreprise propriétaire
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now())
  address       String?
  businessEmail String?
  city          String?
  country       String?
  industry      String?
  phone         String?
  plan          Plan       @default(STARTER)
  postalCode    String?
  region        String?
  rejectedAt    DateTime?
  rejectionNote String?
  size          String?
  validatedAt   DateTime?
  validatedById String?
  logoUrl            String?
  primaryColor       String?
  secondaryColor     String?
  accentColor        String?
  legalName          String?
  registrationNumber String?
  vatNumber          String?
  // ─── Branding V2 Sprint 1 ───────────────────────────
  backgroundColor    String?
  faviconUrl         String?
  welcomeMessage     String?
  customDomain       String?
  maxFamilyMembers   Int      @default(5)
  // ─── V3 Sprint 1 ────────────────────────────────────
  countryCode        String   @default("CI")
  currencyCode       String   @default("XOF")
  defaultLocale      String   @default("fr")
  developerApiEnabled Boolean @default(false)

  auditLogs     AuditLog[]
  users         User[]
  invitationTokens InvitationToken[]

  employees        Employee[]
  familyMembers    FamilyMember[]
  tickets          Ticket[]
  benefitCategories BenefitCategory[]
  benefitRequests  BenefitRequest[]
  complianceRequirements ComplianceRequirement[]
  expenseReports   ExpenseReport[]
  travelRequests   TravelRequest[]
  conversations    Conversation[]
  subscription     Subscription?
  invoices         Invoice[]
  apiIntegrations  ApiIntegration[]
  events           Event[]
  csePosts         CsePost[]
  benefitCatalog   BenefitCatalogItem[]
  travelPolicies   TravelPolicy[]
  groupTravels     GroupTravel[]
  travelRewards    TravelReward[]
  ocrScans         OcrScan[]
  eventPhotos      EventPhoto[]
  faqEntries       FaqEntry[]
  wallets          Wallet[]
  cashbackRules    CashbackRule[]
  orders           Order[]
  bookings         Booking[]
  apiClients       ApiClient[]
  webhookEndpoints WebhookEndpoint[]

  @@map("organizations")
}

model User {
  id                     String       @id @default(uuid())
  email                  String       @unique
  password               String
  role                   Role         @default(EMPLOYE)
  firstName              String
  lastName               String
  isActive               Boolean      @default(true)
  refreshToken           String?
  lastLoginAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @default(now())
  organizationId         String
  avatar                 String?
  costCenter             String?
  department             String?
  emailVerified          Boolean      @default(false)
  emailVerifiedAt        DateTime?
  jobTitle               String?
  managerId              String?
  phone                  String?
  profileCompleted       Boolean      @default(false)
  resetPasswordExpiresAt DateTime?
  resetPasswordToken     String?
  timezone               String       @default("Africa/Lome")
  dateFormat             String       @default("DD/MM/YYYY")
  notificationPreferences Json        @default("{\"email\":true,\"travelAlerts\":true,\"cseUpdates\":true,\"systemUpdates\":true}")
  auditLogs              AuditLog[]
  manager                User?        @relation("UserManager", fields: [managerId], references: [id])
  managedUsers           User[]       @relation("UserManager")
  organization           Organization @relation(fields: [organizationId], references: [id])

  employee         Employee?
  sentMessages     Message[]        @relation("MessageSender")
  conversations    ConversationParticipant[]

  eventRegistrations EventRegistration[]
  postLikes          PostLike[]          @relation("PostLiker")
  postComments       PostComment[]       @relation("CommentAuthor")
  pollVotes          PollVote[]          @relation("PollVoter")
  authoredPosts      CsePost[]           @relation("PostAuthor")
  documents          UserDocument[]
  travelRequests     TravelRequest[]     @relation("TravelRequester")
  notifications      Notification[]
  familyMembers      FamilyMember[]
  tickets            Ticket[]
  travelRewards      TravelReward[]      @relation("TravelRewardUser")
  ocrScans           OcrScan[]           @relation("OcrScanUser")
  ledGroupTravels    GroupTravel[]       @relation("GroupTravelLeader")
  groupParticipations GroupTravelParticipant[] @relation("GroupTravelParticipant")
  uploadedPhotos     EventPhoto[]        @relation("EventPhotoUploader")
  eventPhotoLikes    EventPhotoLike[]    @relation("EventPhotoLiker")
  faqEntriesAuthored FaqEntry[]          @relation("FaqEntryAuthor")
  faqVotes           FaqVote[]           @relation("FaqVoter")
  // ─── V3 Sprint 1 ────────────────────────────────────
  memberCardToken    String?
  notifNewPartnerOffer Boolean           @default(true)
  preferredLocale    String              @default("fr")
  wallet             Wallet?
  cashbackTransactions CashbackTransaction[]
  orders             Order[]
  bookings           Booking[]

  @@map("users")
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entity         String
  entityId       String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum Plan {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum Role {
  ADMIN
  MANAGER
  RH
  FINANCE
  EMPLOYE
  SUPER_ADMIN
  PLATFORM_MANAGER
  PARTNER_ADMIN
  PARTNER_STAFF
}


// ─── PLATFORM SETTINGS ─────────────────────────────────

model PlatformSettings {
  id                    String   @id @default("singleton") // Un seul enregistrement

  logoUrl               String?
  primaryColor          String   @default("#0f766e")
  secondaryColor        String   @default("#f59e0b")
  darkModeEnabled       Boolean  @default(true)

  faviconUrl            String?

  manualValidation      Boolean  @default(true)
  autoRegistration      Boolean  @default(false)

  defaultHasCSE         Boolean  @default(false)
  defaultHasVoyage      Boolean  @default(false)

  notifyOnValidation    Boolean  @default(true)
  notifyOnRejection     Boolean  @default(true)
  notifyWelcome         Boolean  @default(false)

  updatedAt             DateTime @updatedAt

  @@map("platform_settings")
}

// ─── PLAN ──────────────────────────────────────────────

model PlanConfig {
  id                String   @id @default(cuid())
  name              String   @unique // "STARTER", "BUSINESS", "ENTERPRISE"
  label             String
  price             String            // Libellé affiché ("Gratuit", "Sur devis")
  pricePerEmployee  Decimal? @db.Decimal(10,2) // Prix/employé actif/mois
  billingCycle      String?           // "MONTHLY" | "ANNUAL"
  maxUsers          Int?
  hasVoyage         Boolean  @default(false)
  hasCSE            Boolean  @default(false)
  features          String[]
  apiAccess         Boolean  @default(false)
  webhookAccess     Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("plan_configs")
}

// ─── API DEVELOPER (F29) ────────────────────────────────

model ApiClient {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])
  name        String
  keyPrefix   String       // Premiers 12 chars visibles en UI
  keyHash     String       @unique // SHA-256 de la clé complète
  scopes      String[]
  isActive    Boolean      @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  webhooks    WebhookEndpoint[]

  @@map("api_clients")
}

model WebhookEndpoint {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])
  apiClientId String?
  apiClient   ApiClient?   @relation(fields: [apiClientId], references: [id])
  url         String
  secret      String
  events      String[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  deliveries  WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String          @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id])
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?
  attempts     Int             @default(1)
  deliveredAt  DateTime?
  nextRetryAt  DateTime?
  failed       Boolean         @default(false)
  createdAt    DateTime        @default(now())

  @@map("webhook_deliveries")
}

// ─── COUNTRY CONFIG (F31) ──────────────────────────────

model CountryConfig {
  id           String   @id @default(cuid())
  code         String   @unique // "CI", "SN", "CM", "GN", "BF", "ML", "TG", "BJ"
  name         String
  currencyCode String   @default("XOF")
  locale       String   @default("fr")
  taxRate      Decimal  @default(0) @db.Decimal(5,4)
  phonePrefix  String?  // "+225"
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("country_configs")
}

// ─── INVITATION TOKEN ──────────────────────────────────// Token d'activation envoyé à l'admin après validation

model InvitationToken {
  id             String    @id @default(cuid())
  token          String    @unique // Token hashé
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  usedAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@map("invitation_tokens")
}


// ─── Enum ─────────────────────────────────────────────────────────────────────

enum ContactStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─── Model ────────────────────────────────────────────────────────────────────

model ContactRequest {
  id               Int           @id @default(autoincrement())
  fullName         String
  company          String
  email            String
  phone            String        @default("")
  companySize      String        @default("")
  message          String
  acceptMarketing  Boolean       @default(false)
  status           ContactStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("contact_requests")
}




// ─── EMPLOYEE (profil étendu dans l'org) ───────────────
model Employee {
  id             String       @id @default(cuid())
  matricule      String?      // Numéro matricule RH
  avatar         String?      // URL Cloudinary
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id])
  managerId      String?
  manager        Employee?    @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates   Employee[]   @relation("EmployeeManager")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  benefitRequests BenefitRequest[]
  expenseReports  ExpenseReport[]

  @@map("employees")
}

// ─── BENEFIT CATEGORY (catégories de subventions CSE) ──
model BenefitCategory {
  id              String       @id @default(cuid())
  name            String
  description     String?
  icon            String?
  annualBudget    Float        @default(0)
  perEmployeeLimit Float       @default(0)
  currency        String       @default("EUR")
  isActive        Boolean      @default(true)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  eligibleServices String[]    // Liste des services éligibles
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  requests        BenefitRequest[]

  @@map("benefit_categories")
}

// ─── COMPLIANCE (rapport de conformité RGPD/légal) ─────
enum ComplianceStatus {
  CONFORME
  NON_CONFORME
  EN_COURS
}

model ComplianceRequirement {
  id             String           @id @default(cuid())
  label          String
  description    String?
  status         ComplianceStatus @default(EN_COURS)
  lastAuditDate  DateTime?
  nextAuditDate  DateTime?
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("compliance_requirements")
}

// ─── BENEFIT REQUEST (demande d'avantage) ──────────────
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

model BenefitRequest {
  id             String        @id @default(cuid())
  amount         Float
  description    String?
  receipts       String[]      @default([]) // URLs des justificatifs
  status         RequestStatus @default(PENDING)
  urgency        Urgency       @default(LOW)
  rejectionNote  String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  employeeId     String
  employee       Employee      @relation(fields: [employeeId], references: [id])
  categoryId     String
  category       BenefitCategory @relation(fields: [categoryId], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("benefit_requests")
}

// ─── EXPENSE REPORT (notes de frais voyage) ────────────
model ExpenseReport {
  id             String        @id @default(cuid())
  title          String
  description    String?
  destination    String?
  expenseDate    DateTime?
  category       String?
  paymentMethod  String?
  travelId       String?
  travel         TravelRequest? @relation(fields: [travelId], references: [id])
  departureDate  DateTime?
  returnDate     DateTime?
  amount         Float
  co2Emissions   Float?        // en tonnes
  status         RequestStatus @default(PENDING)
  rejectionNote  String?
  department     String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  employeeId     String
  employee       Employee      @relation(fields: [employeeId], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  receipts       String[]      // URLs des justificatifs
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("expense_reports")
}

// ─── TRAVEL REQUEST (réservation voyage) ───────────────
enum TravelStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  IN_PROGRESS
  COMPLETED
}

model TravelRequest {
  id             String        @id @default(cuid())
  destination    String
  purpose        String?
  departureDate  DateTime
  returnDate     DateTime
  estimatedCost  Float?
  actualCost     Float?
  department     String?
  status         TravelStatus  @default(PENDING)
  urgency        Urgency       @default(LOW)
  rejectionNote  String?
  partnerName    String?
  paymentStatus  PaymentStatus @default(PENDING)
  paymentLink    String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  requestedById  String
  requestedBy    User          @relation("TravelRequester", fields: [requestedById], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  tripReminderSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // ─── Sprint 3 ────────────────────────────────────────
  policyId       String?
  policy         TravelPolicy?  @relation(fields: [policyId], references: [id])
  groupTravelId  String?
  groupTravel    GroupTravel?   @relation(fields: [groupTravelId], references: [id])
  reward         TravelReward?  @relation("TravelRequestReward")

  expenses       ExpenseReport[]

  @@map("travel_requests")
}

// ─── MESSAGE ───────────────────────────────────────────
enum ConversationStatus {
  OPEN
  RESOLVED
}

model Conversation {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  participants   ConversationParticipant[]
  messages       Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@map("messages")
}

// ─── SUBSCRIPTION (facturation) ────────────────────────
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  KKIAPAY
  FEDAPAY
}

model Subscription {
  id             String    @id @default(cuid())
  organizationId String    @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           Plan      @default(STARTER)
  status         String    @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoices       Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique // INV-2025-001
  amount         Float
  currency       String        @default("EUR")
  status         PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod?
  paymentRef     String?       // Référence transaction externe
  description    String?
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("invoices")
}

// ─── PLATFORM SETTINGS (ajout champ logo) ──────────────


// ─── API INTEGRATION ───────────────────────────────────
model ApiIntegration {
  id             String       @id @default(cuid())
  name           String       // "SAP SuccessFactors", "Workday", etc.
  type           String       // "HR", "ACCOUNTING"
  apiKey         String?      // Stocké chiffré
  webhookUrl     String?
  isActive       Boolean      @default(false)
  lastSyncAt     DateTime?
  syncConfig     Json?        // Mapping des champs
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  syncLogs        SyncLog[]
  integrationType String   @default("HR_SYSTEM")

  @@map("api_integrations")
}

model SyncLog {
  id              String         @id @default(cuid())
  integrationId   String
  integration     ApiIntegration @relation(fields: [integrationId], references: [id])
  type            String         // "AUTOMATIC", "MANUAL"
  employeesCreated Int           @default(0)
  employeesUpdated Int           @default(0)
  errors          Int            @default(0)
  status          String         // "SUCCESS", "PARTIAL", "FAILED"
  createdAt       DateTime       @default(now())

  @@map("sync_logs")
}


// ─── EVENT (Calendrier CSE) ────────────────────────────
enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model Event {
  id             String      @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  location       String?
  maxParticipants Int?
  icon           String?     // emoji ou URL
  color          String?     // couleur calendrier
  status         EventStatus @default(PUBLISHED)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  registrations  EventRegistration[]
  photos         EventPhoto[]

  @@map("events")
}

model EventRegistration {
  id             String    @id @default(cuid())
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
  reminderSentAt DateTime?

  @@unique([eventId, userId])
  @@map("event_registrations")
}

// ─── CSE POST (Communication) ──────────────────────────
enum PostType {
  ARTICLE
  POLL
  EVENT_ANNOUNCEMENT
}

model CsePost {
  id             String    @id @default(cuid())
  type           PostType  @default(ARTICLE)
  title          String?
  content        String
  imageUrl       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  authorId       String
  author         User      @relation("PostAuthor", fields: [authorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  likes          PostLike[]
  comments       PostComment[]
  pollOptions    PollOption[]

  @@map("cse_posts")
}

model PostLike {
  id     String  @id @default(cuid())
  postId String
  post   CsePost @relation(fields: [postId], references: [id])
  userId String
  user   User    @relation("PostLiker", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      CsePost  @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@map("post_comments")
}

model PollOption {
  id        String   @id @default(cuid())
  label     String
  postId    String
  post      CsePost  @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  votes     PollVote[]

  @@map("poll_options")
}

model PollVote {
  id           String     @id @default(cuid())
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id])
  userId       String
  user         User       @relation("PollVoter", fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([pollOptionId, userId])
  @@map("poll_votes")
}

// ─── BENEFIT CATALOG (catalogue avantages employé) ─────
model BenefitCatalogItem {
  id               String    @id @default(cuid())
  title            String
  description      String?
  imageUrl         String?
  category         String
  subsidyPct       Int       // % existant V1 — voir subsidyAmount pour le montant fixe V2
  employeePrice    Float
  companyPrice     Float
  validUntil       DateTime?
  maxPerFamily     Int?
  isActive         Boolean   @default(true)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // ─── Champs V2 Sprint 1 ─────────────────────────────
  partnerId          String?
  partner            Partner?  @relation(fields: [partnerId], references: [id])
  offerType          OfferType @default(VOUCHER)
  isFeatured         Boolean   @default(false)
  isCommitteeChoice  Boolean   @default(false)
  boostUntil         DateTime?
  boostLabel         String?
  subsidyAmount      Decimal?  @db.Decimal(10,2)
  subsidyStart       DateTime?
  subsidyEnd         DateTime?
  city               String?
  region             String?
  country            String?
  latitude           Decimal?  @db.Decimal(9,6)
  longitude          Decimal?  @db.Decimal(9,6)
  requiresTicket     Boolean   @default(false)
  requiresFamilyMember Boolean @default(false)
  publishedAt        DateTime?
  unpublishedAt      DateTime?
  validFrom          DateTime?
  stock              Int?
  // ─── V3 Sprint 1 ────────────────────────────────────
  cashbackRuleId     String?
  cashbackRule       CashbackRule? @relation(fields: [cashbackRuleId], references: [id])

  auditEntries     OfferAuditEntry[]
  tickets          Ticket[]
  bookings         Booking[]

  @@map("benefit_catalog_items")
}

// ─── USER DOCUMENT ─────────────────────────────────────
model UserDocument {
  id        String   @id @default(cuid())
  name      String   // "Passport Copy", "National ID"
  url       String   // URL Cloudinary
  type      String   // "PDF", "IMAGE"
  size      String?  // "2.4 MB"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("user_documents")
}

