}

model FaqVote {
  id         String   @id @default(cuid())
  faqEntryId String
  faqEntry   FaqEntry @relation(fields: [faqEntryId], references: [id])
  userId     String
  user       User     @relation("FaqVoter", fields: [userId], references: [id])
  helpful    Boolean
  createdAt  DateTime @default(now())

  @@unique([faqEntryId, userId])
  @@map("faq_votes")
}

// ─── WALLET (V3 Sprint 1) ─────────────────────────────────

enum WalletEntryType {
  ALLOCATION
  DEBIT
  SUBSIDY_CREDIT
  CASHBACK_CREDIT
  CASHBACK_REVERSAL
  REFUND
  EXPIRY
  REWARD_CREDIT
}

model Wallet {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  currencyCode   String    @default("XOF")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  entries        WalletEntry[]

  @@map("wallets")
}

model WalletEntry {
  id              String          @id @default(cuid())
  walletId        String
  wallet          Wallet          @relation(fields: [walletId], references: [id])
  type            WalletEntryType
  // positif = crédit, négatif = débit — jamais modifié après insertion
  amount          Decimal         @db.Decimal(14,2)
  // snapshot du solde après cette entrée (dénormalisation pour perf)
  runningBalance  Decimal         @db.Decimal(14,2)
  description     String?
  referenceId     String?
  referenceType   String?         // ORDER | TICKET | CASHBACK | EXPENSE | ALLOCATION
  idempotencyKey  String          @unique
  expiresAt       DateTime?       // allocations uniquement
  createdAt       DateTime        @default(now())

  @@map("wallet_entries")
}

// ─── CASHBACK (V3 Sprint 1) ──────────────────────────────

enum CashbackType {
  MERCHANT
  EMPLOYER
  HYBRID
  CAMPAIGN
}

enum CashbackStatus {
  CALCULATED
  CREDITED
  PENDING_REVIEW
  REVERSED
  EXPIRED
}

model CashbackRule {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  partnerId      String?
  partner        Partner?     @relation(fields: [partnerId], references: [id])
  type           CashbackType
  rate           Decimal      @db.Decimal(5,4)  // 0.0000 → 1.0000
  fixedAmount    Decimal?     @db.Decimal(14,2)
  maxPerEmployee Decimal?     @db.Decimal(14,2)
  maxPerPeriod   Decimal?     @db.Decimal(14,2)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean      @default(true)
  category       String?
  currencyCode   String       @default("XOF")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions   CashbackTransaction[]
  offers         BenefitCatalogItem[]

  @@map("cashback_rules")
}

model CashbackTransaction {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  organizationId String
  orderId        String?
  ticketId       String?
  ruleId         String
  rule           CashbackRule   @relation(fields: [ruleId], references: [id])
  rawAmount      Decimal        @db.Decimal(14,2)
  creditedAmount Decimal        @db.Decimal(14,2)
  status         CashbackStatus @default(CALCULATED)
  fraudScore     Decimal?       @db.Decimal(5,4) @default(0)
  idempotencyKey String         @unique
  currencyCode   String         @default("XOF")
  createdAt      DateTime       @default(now())

  @@map("cashback_transactions")
}

model FraudSignal {
  id            String   @id @default(cuid())
  userId        String
  transactionId String
  signalType    String   // HIGH_FREQUENCY | SAME_MERCHANT | AMOUNT_ANOMALY
  score         Decimal  @db.Decimal(5,4)
  metadata      Json?
  reviewed      Boolean  @default(false)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())

  @@map("fraud_signals")
}

// ─── ORDER (V3 Sprint 1) ─────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  COMPLETED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

model Order {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id])
  partnerId       String?
  offerId         String?
  amount          Decimal            @db.Decimal(14,2)
  discountAmount  Decimal            @db.Decimal(14,2) @default(0)
  subsidyAmount   Decimal            @db.Decimal(14,2) @default(0)
  cashbackAmount  Decimal            @db.Decimal(14,2) @default(0)
  finalAmount     Decimal            @db.Decimal(14,2)
  currencyCode    String             @default("XOF")
  paymentMethod   String?            // WALLET | MOBILE_MONEY | CARD
  paymentStatus   OrderPaymentStatus @default(UNPAID)
  transactionId   String?
  idempotencyKey  String             @unique
  status          OrderStatus        @default(PENDING)
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  booking         Booking?

  @@map("orders")
}
// ═══════════════════════════════════════════════════════════════════════════
// V3 SPRINT 2 — Portail partenaire (F21), Booking (F22), Commissions (F23)
// ═══════════════════════════════════════════════════════════════════════════

// ─── Nouveaux enums ──────────────────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REJECTED
  NO_SHOW
}

enum CommissionType {
  PERCENTAGE
  FIXED
  MAX_OF_BOTH
}

enum CommissionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REVERSED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Portail partenaire ──────────────────────────────────────────────────────

model PartnerUser {
  id           String    @id @default(cuid())
  partnerId    String
  partner      Partner   @relation(fields: [partnerId], references: [id])
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role      @default(PARTNER_ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  invitedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("partner_users")
}

model PartnerLocation {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id])
  name        String
  address     String
  city        String
  country     String    @default("CI")
  latitude    Decimal?  @db.Decimal(10,7)
  longitude   Decimal?  @db.Decimal(10,7)
  phone       String?
  isMain      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  availabilities PartnerAvailability[]
  bookings       Booking[]

  @@map("partner_locations")
}

model PartnerAvailability {
  id            String    @id @default(cuid())
  locationId    String
  location      PartnerLocation @relation(fields: [locationId], references: [id])
  dayOfWeek     Int?      // 0=Sun … 6=Sat — null = exception
  openTime      String    // HH:MM
  closeTime     String    // HH:MM
  isClosed      Boolean   @default(false)
  exceptionDate DateTime? // set → exception date, null → weekly schedule
  note          String?
  createdAt     DateTime  @default(now())

  @@map("partner_availabilities")
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  partnerId       String
  partner         Partner       @relation(fields: [partnerId], references: [id])
  offerId         String?
  offer           BenefitCatalogItem? @relation(fields: [offerId], references: [id])
  locationId      String?
  location        PartnerLocation?    @relation(fields: [locationId], references: [id])
  orderId         String?       @unique
  order           Order?        @relation(fields: [orderId], references: [id])

  status          BookingStatus @default(PENDING)
  bookingDate     DateTime
  numberOfPersons Int           @default(1)
  notes           String?
  partnerNotes    String?
  idempotencyKey  String        @unique

  confirmedAt  DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  commissionEntry CommissionEntry?
  rating          BookingRating?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model BookingRating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  userId    String
  score     Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  @@map("booking_ratings")
}

// ─── Catalogue Voyage (recherche DB-backed — remplace Amadeus) ───────────────

model Airport {
  id        String   @id @default(cuid())
  iataCode  String   @unique
  name      String
  city      String
  country   String
  createdAt DateTime @default(now())

  @@map("airports")
}

model FlightRoute {
  id              String   @id @default(cuid())
  partnerId       String
  partner         Partner  @relation(fields: [partnerId], references: [id])
  airlineCode     String
  originIata      String
  originCity      String
  destinationIata String
  destinationCity String
  departureTime   String   // "HH:MM"
  durationMinutes Int
  stops           Int      @default(0)
  basePrice       Decimal  @db.Decimal(10,2)
  currency        String   @default("XOF")
  operatingDays   Int[]    @default([]) // 0=Dim..6=Sam, [] = tous les jours
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([originIata, destinationIata])
  @@map("flight_routes")
}

model HotelProperty {
  id         String   @id @default(cuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id])
  name       String
  city       String
  country    String
  address    String?
  starRating Int?
  imageUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  roomTypes HotelRoomType[]

  @@index([city])
  @@map("hotel_properties")
}

model HotelRoomType {
  id            String        @id @default(cuid())
  hotelId       String
  hotel         HotelProperty @relation(fields: [hotelId], references: [id])
  name          String
  capacity      Int           @default(2)
  pricePerNight Decimal       @db.Decimal(10,2)
  currency      String        @default("XOF")
  totalRooms    Int           @default(1)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  @@map("hotel_room_types")
}

model TrainRoute {
  id                 String   @id @default(cuid())
  partnerId          String
  partner            Partner  @relation(fields: [partnerId], references: [id])
  originCity         String
  originStation      String
  destinationCity    String
  destinationStation String
  departureTime      String
  durationMinutes    Int
  basePrice          Decimal  @db.Decimal(10,2)
  currency           String   @default("XOF")
  travelClass        String   @default("Économique")
  operatingDays      Int[]    @default([])
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([originCity, destinationCity])
  @@map("train_routes")
}

model CarRentalVehicle {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id])
  category     String   // Économique | Compacte | SUV | Luxe | Utilitaire
  brand        String
  model        String
  city         String
  country      String
  pricePerDay  Decimal  @db.Decimal(10,2)
  currency     String   @default("XOF")
  seats        Int      @default(5)
  transmission String   @default("MANUELLE") // MANUELLE | AUTOMATIQUE
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([city])
  @@map("car_rental_vehicles")
}

// ─── Commissions ─────────────────────────────────────────────────────────────

model CommissionRule {
  id           String         @id @default(cuid())
  partnerId    String?
  partner      Partner?       @relation(fields: [partnerId], references: [id])
  category     String?
  type         CommissionType @default(PERCENTAGE)
  rate         Decimal        @db.Decimal(5,4)    // 0.10 = 10%
  fixedAmount  Decimal?       @db.Decimal(14,2)
  currencyCode String         @default("XOF")
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  entries      CommissionEntry[]

  @@map("commission_rules")
}

model CommissionEntry {
  id               String           @id @default(cuid())
  bookingId        String           @unique
  booking          Booking          @relation(fields: [bookingId], references: [id])
  ruleId           String
  rule             CommissionRule   @relation(fields: [ruleId], references: [id])
  partnerId        String
  partner          Partner          @relation(fields: [partnerId], references: [id])

  grossAmount      Decimal          @db.Decimal(14,2)
  commissionAmount Decimal          @db.Decimal(14,2)
  netAmount        Decimal          @db.Decimal(14,2)
  currencyCode     String           @default("XOF")

  status           CommissionStatus @default(PENDING)
  payoutId         String?
  payout           PartnerPayout?   @relation(fields: [payoutId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commission_entries")
}

model PartnerPayout {
  id              String      @id @default(cuid())
  partnerId       String
  partner         Partner     @relation(fields: [partnerId], references: [id])
  period          String      // e.g., "2026-07"

  totalGross      Decimal     @db.Decimal(14,2)
  totalCommission Decimal     @db.Decimal(14,2)
  netAmount       Decimal     @db.Decimal(14,2)
  currencyCode    String      @default("XOF")

  status          PayoutStatus @default(PENDING)
  paymentMethod   String?
  paidAt          DateTime?
  notes           String?
  triggeredById   String?

  entries         CommissionEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_payouts")
}
