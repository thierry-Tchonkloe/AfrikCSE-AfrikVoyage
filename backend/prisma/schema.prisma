// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// в”Ђв”Ђв”Ђ ENUMS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum OrgStatus {
  PENDING       // En attente de validation par Super Admin
  ACTIVE        // Active
  SUSPENDED     // Suspendue
  REJECTED      // RefusГ©e par Super Admin
}

enum Plan {
  STARTER       // Petit plan
  BUSINESS      // Plan intermГ©diaire
  ENTERPRISE    // Plan complet
}

enum Role {
  ADMIN
  MANAGER
  RH
  FINANCE
  EMPLOYE
  SUPER_ADMIN
}



// в”Ђв”Ђв”Ђ ORGANIZATION в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ


model Organization {
  id              String      @id @default(uuid())
  name            String
  email           String      @unique
  slug            String      @unique

  status          OrgStatus   @default(PENDING)
  plan            Plan        @default(STARTER)

  hasVoyage       Boolean     @default(false)
  hasCSE          Boolean     @default(false)


  country         String?
  phone           String?
  size            String?     // "1-10", "11-50", "51-200", etc.
  industry        String?
  address         String?
  city            String?
  region          String?
  postalCode      String?
  businessEmail   String?

  validatedAt     DateTime?
  validatedById   String?   // ID du Super Admin qui a validГ©
  rejectedAt      DateTime?
  rejectionNote   String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now())

  users           User[]

  auditLogs       AuditLog[]
  @@map("organizations")
}

// в”Ђв”Ђв”Ђ USER в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model User {
  id                      String      @id @default(uuid())
  email                   String      @unique
  password                String

  firstName               String
  lastName                String
  phone                   String?
  avatar                  String?      // URL Cloudinary
  jobTitle                String?
  department              String?
  costCenter              String?

  role                    Role         @default(EMPLOYE)
  isActive                Boolean      @default(true)

  profileCompleted        Boolean      @default(false)

  emailVerified           Boolean      @default(false)
  emailVerifiedAt         DateTime?

  refreshToken            String?      // StockГ© hashГ©
  resetPasswordToken      String?      // Token reset password (hashГ©)
  resetPasswordExpiresAt  DateTime?

  managerId               String?
  manager                 User?        @relation("UserManager", fields: [managerId], references: [id])
  managedUsers            User[]       @relation("UserManager")

  lastLoginAt             DateTime?

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @default(now())

  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id])

  auditLogs               AuditLog[]

  @@map("users")
}


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ AUDIT LOG : Trace toutes les actions sensiblesв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ


model AuditLog {
  id            String   @id @default(cuid())
  action        String   // "USER_CREATED", "ROLE_CHANGED", "ORG_VALIDATED", etc.
  entity        String   // "User", "Organization"
  entityId      String
  oldValue      Json?    // Valeur avant modification
  newValue      Json?    // Valeur aprГЁs modification
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  // Qui a effectuГ© l'action

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  // Sur quelle organisation

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("audit_logs")
}