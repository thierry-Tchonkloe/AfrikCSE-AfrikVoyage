  status          RewardStatus  @default(EARNED)
  estimatedCost   Decimal?      @db.Decimal(10,2)
  actualCost      Decimal?      @db.Decimal(10,2)
  savedAmount     Decimal?      @db.Decimal(10,2)
  currency        String        @default("XOF")
  expiresAt       DateTime?
  redeemedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@map("travel_rewards")
}

// ─── OCR SCAN (V2 Sprint 3) ──────────────────────────────

enum OcrStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model OcrScan {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("OcrScanUser", fields: [userId], references: [id])
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  fileUrl         String
  rawText         String?
  extractedData   Json?         // { amount, date, vendor, currency }
  status          OcrStatus     @default(PENDING)
  errorMessage    String?
  expenseReportId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("ocr_scans")
}

// ─── EVENT PHOTO (V2 Sprint 4) ────────────────────────────

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

model EventPhoto {
  id             String      @id @default(cuid())
  eventId        String
  event          Event       @relation(fields: [eventId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  uploadedBy     String
