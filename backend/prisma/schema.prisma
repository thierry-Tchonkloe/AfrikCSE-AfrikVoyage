generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String     @id @default(uuid())
  name          String
  email         String?    @unique
  slug          String     @unique
  status        OrgStatus  @default(PENDING)
  hasVoyage     Boolean    @default(false)
  hasCSE        Boolean    @default(false)
  isHost        Boolean    @default(false) // True pour l'entreprise propriétaire
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now())
  address       String?
  businessEmail String?
  city          String?
  country       String?
  industry      String?
  phone         String?
  plan          Plan       @default(STARTER)
  postalCode    String?
  region        String?
  rejectedAt    DateTime?
  rejectionNote String?
  size          String?
  validatedAt   DateTime?
  validatedById String?
  logoUrl            String?
  primaryColor       String?
  secondaryColor     String?
  accentColor        String?
  legalName          String?
  registrationNumber String?
  vatNumber          String?
  // ─── Branding V2 Sprint 1 ───────────────────────────
  backgroundColor    String?
  faviconUrl         String?
  welcomeMessage     String?
  customDomain       String?
  maxFamilyMembers   Int      @default(5)
  auditLogs     AuditLog[]
  users         User[]
  invitationTokens InvitationToken[]

  employees        Employee[]
  familyMembers    FamilyMember[]
  tickets          Ticket[]
  benefitCategories BenefitCategory[]
  benefitRequests  BenefitRequest[]
  complianceRequirements ComplianceRequirement[]
  expenseReports   ExpenseReport[]
  travelRequests   TravelRequest[]
  conversations    Conversation[]
  subscription     Subscription?
  invoices         Invoice[]
  apiIntegrations  ApiIntegration[]
  events           Event[]
  csePosts         CsePost[]
  benefitCatalog   BenefitCatalogItem[]
  travelPolicies   TravelPolicy[]
  groupTravels     GroupTravel[]
  travelRewards    TravelReward[]
  ocrScans         OcrScan[]
  eventPhotos      EventPhoto[]
  faqEntries       FaqEntry[]

  @@map("organizations")
}

model User {
  id                     String       @id @default(uuid())
  email                  String       @unique
  password               String
  role                   Role         @default(EMPLOYE)
  firstName              String
  lastName               String
  isActive               Boolean      @default(true)
  refreshToken           String?
  lastLoginAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @default(now())
  organizationId         String
  avatar                 String?
  costCenter             String?
  department             String?
  emailVerified          Boolean      @default(false)
  emailVerifiedAt        DateTime?
  jobTitle               String?
  managerId              String?
  phone                  String?
  profileCompleted       Boolean      @default(false)
  resetPasswordExpiresAt DateTime?
  resetPasswordToken     String?
  timezone               String       @default("Africa/Lome")
  dateFormat             String       @default("DD/MM/YYYY")
  notificationPreferences Json        @default("{\"email\":true,\"travelAlerts\":true,\"cseUpdates\":true,\"systemUpdates\":true}")
  auditLogs              AuditLog[]
  manager                User?        @relation("UserManager", fields: [managerId], references: [id])
  managedUsers           User[]       @relation("UserManager")
  organization           Organization @relation(fields: [organizationId], references: [id])

  employee         Employee?
  sentMessages     Message[]        @relation("MessageSender")
  conversations    ConversationParticipant[]

  eventRegistrations EventRegistration[]
  postLikes          PostLike[]          @relation("PostLiker")
  postComments       PostComment[]       @relation("CommentAuthor")
  pollVotes          PollVote[]          @relation("PollVoter")
  authoredPosts      CsePost[]           @relation("PostAuthor")
  documents          UserDocument[]
  travelRequests     TravelRequest[]     @relation("TravelRequester")
  notifications      Notification[]
  familyMembers      FamilyMember[]
  tickets            Ticket[]
  travelRewards      TravelReward[]      @relation("TravelRewardUser")
  ocrScans           OcrScan[]           @relation("OcrScanUser")
  ledGroupTravels    GroupTravel[]       @relation("GroupTravelLeader")
  groupParticipations GroupTravelParticipant[] @relation("GroupTravelParticipant")
  uploadedPhotos     EventPhoto[]        @relation("EventPhotoUploader")
  eventPhotoLikes    EventPhotoLike[]    @relation("EventPhotoLiker")
  faqEntriesAuthored FaqEntry[]          @relation("FaqEntryAuthor")
  faqVotes           FaqVote[]           @relation("FaqVoter")

  @@map("users")
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entity         String
  entityId       String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum Plan {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum Role {
  ADMIN
  MANAGER
  RH
  FINANCE
  EMPLOYE
  SUPER_ADMIN
}


// ─── PLATFORM SETTINGS ─────────────────────────────────

model PlatformSettings {
  id                    String   @id @default("singleton") // Un seul enregistrement

  logoUrl               String?
  primaryColor          String   @default("#0f766e")
  secondaryColor        String   @default("#f59e0b")
  darkModeEnabled       Boolean  @default(true)

  faviconUrl            String?

  manualValidation      Boolean  @default(true)
  autoRegistration      Boolean  @default(false)

  defaultHasCSE         Boolean  @default(false)
  defaultHasVoyage      Boolean  @default(false)

  notifyOnValidation    Boolean  @default(true)
  notifyOnRejection     Boolean  @default(true)
  notifyWelcome         Boolean  @default(false)

  updatedAt             DateTime @updatedAt

  @@map("platform_settings")
}

// ─── PLAN ──────────────────────────────────────────────

model PlanConfig {
  id          String   @id @default(cuid())
  name        String   @unique // "STARTER", "BUSINESS", "ENTERPRISE"
  label       String            // Nom affiché
  price       String            // "Gratuit", "Sur devis", etc.
  maxUsers    Int?              // null = illimité
  hasVoyage   Boolean  @default(false)
  hasCSE      Boolean  @default(false)
  features    String[]          // Liste des fonctionnalités
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plan_configs")
}

// ─── INVITATION TOKEN ──────────────────────────────────// Token d'activation envoyé à l'admin après validation

model InvitationToken {
  id             String    @id @default(cuid())
  token          String    @unique // Token hashé
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  usedAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@map("invitation_tokens")
}


// ─── Enum ─────────────────────────────────────────────────────────────────────

enum ContactStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─── Model ────────────────────────────────────────────────────────────────────

model ContactRequest {
  id               Int           @id @default(autoincrement())
  fullName         String
  company          String
  email            String
  phone            String        @default("")
  companySize      String        @default("")
  message          String
  acceptMarketing  Boolean       @default(false)
  status           ContactStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("contact_requests")
}




// ─── EMPLOYEE (profil étendu dans l'org) ───────────────
model Employee {
  id             String       @id @default(cuid())
  matricule      String?      // Numéro matricule RH
  avatar         String?      // URL Cloudinary
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id])
  managerId      String?
  manager        Employee?    @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates   Employee[]   @relation("EmployeeManager")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  benefitRequests BenefitRequest[]
  expenseReports  ExpenseReport[]

  @@map("employees")
}

// ─── BENEFIT CATEGORY (catégories de subventions CSE) ──
model BenefitCategory {
  id              String       @id @default(cuid())
  name            String
  description     String?
  icon            String?
  annualBudget    Float        @default(0)
  perEmployeeLimit Float       @default(0)
  currency        String       @default("EUR")
  isActive        Boolean      @default(true)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  eligibleServices String[]    // Liste des services éligibles
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  requests        BenefitRequest[]

  @@map("benefit_categories")
}

// ─── COMPLIANCE (rapport de conformité RGPD/légal) ─────
enum ComplianceStatus {
  CONFORME
  NON_CONFORME
  EN_COURS
}

model ComplianceRequirement {
  id             String           @id @default(cuid())
  label          String
  description    String?
  status         ComplianceStatus @default(EN_COURS)
  lastAuditDate  DateTime?
  nextAuditDate  DateTime?
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("compliance_requirements")
}

// ─── BENEFIT REQUEST (demande d'avantage) ──────────────
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

model BenefitRequest {
  id             String        @id @default(cuid())
  amount         Float
  description    String?
  receipts       String[]      @default([]) // URLs des justificatifs
  status         RequestStatus @default(PENDING)
  urgency        Urgency       @default(LOW)
  rejectionNote  String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  employeeId     String
  employee       Employee      @relation(fields: [employeeId], references: [id])
  categoryId     String
  category       BenefitCategory @relation(fields: [categoryId], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("benefit_requests")
}

// ─── EXPENSE REPORT (notes de frais voyage) ────────────
model ExpenseReport {
  id             String        @id @default(cuid())
  title          String
  description    String?
  destination    String?
  expenseDate    DateTime?
  category       String?
  paymentMethod  String?
  travelId       String?
  travel         TravelRequest? @relation(fields: [travelId], references: [id])
  departureDate  DateTime?
  returnDate     DateTime?
  amount         Float
  co2Emissions   Float?        // en tonnes
  status         RequestStatus @default(PENDING)
  rejectionNote  String?
  department     String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  employeeId     String
  employee       Employee      @relation(fields: [employeeId], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  receipts       String[]      // URLs des justificatifs
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("expense_reports")
}

// ─── TRAVEL REQUEST (réservation voyage) ───────────────
enum TravelStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  IN_PROGRESS
  COMPLETED
}

model TravelRequest {
  id             String        @id @default(cuid())
  destination    String
  purpose        String?
  departureDate  DateTime
  returnDate     DateTime
  estimatedCost  Float?
  actualCost     Float?
  department     String?
  status         TravelStatus  @default(PENDING)
  urgency        Urgency       @default(LOW)
  rejectionNote  String?
  partnerName    String?
  paymentStatus  PaymentStatus @default(PENDING)
  paymentLink    String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  requestedById  String
  requestedBy    User          @relation("TravelRequester", fields: [requestedById], references: [id])
  approvedById   String?
  approvedAt     DateTime?
  tripReminderSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // ─── Sprint 3 ────────────────────────────────────────
  policyId       String?
  policy         TravelPolicy?  @relation(fields: [policyId], references: [id])
  groupTravelId  String?
  groupTravel    GroupTravel?   @relation(fields: [groupTravelId], references: [id])
  reward         TravelReward?  @relation("TravelRequestReward")

  expenses       ExpenseReport[]

  @@map("travel_requests")
}

// ─── MESSAGE ───────────────────────────────────────────
enum ConversationStatus {
  OPEN
  RESOLVED
}

model Conversation {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  participants   ConversationParticipant[]
  messages       Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@map("messages")
}

// ─── SUBSCRIPTION (facturation) ────────────────────────
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  KKIAPAY
  FEDAPAY
}

model Subscription {
  id             String    @id @default(cuid())
  organizationId String    @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           Plan      @default(STARTER)
  status         String    @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoices       Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique // INV-2025-001
  amount         Float
  currency       String        @default("EUR")
  status         PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod?
  paymentRef     String?       // Référence transaction externe
  description    String?
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("invoices")
}

// ─── PLATFORM SETTINGS (ajout champ logo) ──────────────


// ─── API INTEGRATION ───────────────────────────────────
model ApiIntegration {
  id             String       @id @default(cuid())
  name           String       // "SAP SuccessFactors", "Workday", etc.
  type           String       // "HR", "ACCOUNTING"
  apiKey         String?      // Stocké chiffré
  webhookUrl     String?
  isActive       Boolean      @default(false)
  lastSyncAt     DateTime?
  syncConfig     Json?        // Mapping des champs
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  syncLogs        SyncLog[]
  integrationType String   @default("HR_SYSTEM")

  @@map("api_integrations")
}

model SyncLog {
  id              String         @id @default(cuid())
  integrationId   String
  integration     ApiIntegration @relation(fields: [integrationId], references: [id])
  type            String         // "AUTOMATIC", "MANUAL"
  employeesCreated Int           @default(0)
  employeesUpdated Int           @default(0)
  errors          Int            @default(0)
  status          String         // "SUCCESS", "PARTIAL", "FAILED"
  createdAt       DateTime       @default(now())

  @@map("sync_logs")
}


// ─── EVENT (Calendrier CSE) ────────────────────────────
enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model Event {
  id             String      @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  location       String?
  maxParticipants Int?
  icon           String?     // emoji ou URL
  color          String?     // couleur calendrier
  status         EventStatus @default(PUBLISHED)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  registrations  EventRegistration[]
  photos         EventPhoto[]

  @@map("events")
}

model EventRegistration {
  id             String    @id @default(cuid())
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
  reminderSentAt DateTime?

  @@unique([eventId, userId])
  @@map("event_registrations")
}

// ─── CSE POST (Communication) ──────────────────────────
enum PostType {
  ARTICLE
  POLL
  EVENT_ANNOUNCEMENT
}

model CsePost {
  id             String    @id @default(cuid())
  type           PostType  @default(ARTICLE)
  title          String?
  content        String
  imageUrl       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  authorId       String
  author         User      @relation("PostAuthor", fields: [authorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  likes          PostLike[]
  comments       PostComment[]
  pollOptions    PollOption[]

  @@map("cse_posts")
}

model PostLike {
  id     String  @id @default(cuid())
  postId String
  post   CsePost @relation(fields: [postId], references: [id])
  userId String
  user   User    @relation("PostLiker", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      CsePost  @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@map("post_comments")
}

model PollOption {
  id        String   @id @default(cuid())
  label     String
  postId    String
  post      CsePost  @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  votes     PollVote[]

  @@map("poll_options")
}

model PollVote {
  id           String     @id @default(cuid())
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id])
  userId       String
  user         User       @relation("PollVoter", fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([pollOptionId, userId])
  @@map("poll_votes")
}

// ─── BENEFIT CATALOG (catalogue avantages employé) ─────
model BenefitCatalogItem {
  id               String    @id @default(cuid())
  title            String
  description      String?
  imageUrl         String?
  category         String
  subsidyPct       Int       // % existant V1 — voir subsidyAmount pour le montant fixe V2
  employeePrice    Float
  companyPrice     Float
  validUntil       DateTime?
  maxPerFamily     Int?
  isActive         Boolean   @default(true)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // ─── Champs V2 Sprint 1 ─────────────────────────────
  partnerId          String?
  partner            Partner?  @relation(fields: [partnerId], references: [id])
  offerType          OfferType @default(VOUCHER)
  isFeatured         Boolean   @default(false)
  isCommitteeChoice  Boolean   @default(false)
  boostUntil         DateTime?
  boostLabel         String?
  subsidyAmount      Decimal?  @db.Decimal(10,2)
  subsidyStart       DateTime?
  subsidyEnd         DateTime?
  city               String?
  region             String?
  country            String?
  latitude           Decimal?  @db.Decimal(9,6)
  longitude          Decimal?  @db.Decimal(9,6)
  requiresTicket     Boolean   @default(false)
  requiresFamilyMember Boolean @default(false)
  publishedAt        DateTime?
  unpublishedAt      DateTime?
  validFrom          DateTime?
  stock              Int?

  auditEntries     OfferAuditEntry[]
  tickets          Ticket[]

  @@map("benefit_catalog_items")
}

// ─── USER DOCUMENT ─────────────────────────────────────
model UserDocument {
  id        String   @id @default(cuid())
  name      String   // "Passport Copy", "National ID"
  url       String   // URL Cloudinary
  type      String   // "PDF", "IMAGE"
  size      String?  // "2.4 MB"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("user_documents")
}

// ─── NOTIFICATION (notifications push in-app) ──────────
enum NotificationType {
  APPROVAL_REQUEST
  REQUEST_APPROVED
  REQUEST_REJECTED
  TRIP_REMINDER
  NEW_EVENT
  MESSAGE_RECEIVED
  SYSTEM_UPDATE
  NEW_PARTNER_OFFER
  PHOTO_PENDING_MODERATION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      NotificationType @default(SYSTEM_UPDATE)
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ─── PARTNER (V2 Sprint 1) ─────────────────────────────

enum PartnerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PartnerScope {
  CSE
  VOYAGE
  BOTH
}

enum OfferType {
  VOUCHER
  BOOKING
  DISCOUNT_CODE
}

model Partner {
  id              String        @id @default(cuid())
  name            String
  sector          String
  logoUrl         String?
  contactEmail    String?
  websiteUrl      String?
  notes           String?
  status          PartnerStatus @default(DRAFT)
  scopeType       PartnerScope  @default(CSE)
  apiEnabled      Boolean       @default(false)
  apiBaseUrl      String?
  apiKeyEncrypted String?
  apiFormat       String?
  syncFrequencyH  Int           @default(24)
  isGlobal        Boolean       @default(true)
  organizationIds String[]
  partnerToken    String?       @unique
  warningCount    Int           @default(0)
  flaggedAt       DateTime?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  offers       BenefitCatalogItem[]
  syncLogs     PartnerSyncLog[]
  auditEntries OfferAuditEntry[]

  @@map("partners")
}

model PartnerSyncLog {
  id            String   @id @default(cuid())
  partnerId     String
  partner       Partner  @relation(fields: [partnerId], references: [id])
  type          String
  offersCreated Int      @default(0)
  offersUpdated Int      @default(0)
  errors        Int      @default(0)
  status        String
  errorDetail   String?
  createdAt     DateTime @default(now())

  @@map("partner_sync_logs")
}

model OfferAuditEntry {
  id        String   @id @default(cuid())
  offerId   String
  offer     BenefitCatalogItem @relation(fields: [offerId], references: [id])
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])
  action    String
  changedBy String
  snapshot  Json
  version   Int
  createdAt DateTime @default(now())

  @@map("offer_audit_entries")
}

// ─── FAMILY MEMBER (V2 Sprint 2) ──────────────────────────

enum FamilyRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  OTHER
}

model FamilyMember {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  firstName      String
  lastName       String
  relationship   FamilyRelationship
  birthDate      DateTime?
  documentUrl    String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tickets        Ticket[]

  @@map("family_members")
}

// ─── TICKET QR (V2 Sprint 2) ──────────────────────────────

enum TicketStatus {
  VALID
  USED
  EXPIRED
  CANCELLED
}

model Ticket {
  id              String            @id @default(cuid())
  code            String            @unique
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  offerId         String
  offer           BenefitCatalogItem @relation(fields: [offerId], references: [id])
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  familyMemberId  String?
  familyMember    FamilyMember?     @relation(fields: [familyMemberId], references: [id])
  qrPayload       String            // JSON HMAC-signé — ne jamais exposer directement
  status          TicketStatus      @default(VALID)
  usedAt          DateTime?
  expiresAt       DateTime?
  idempotencyKey  String            @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("tickets")
}

// ─── TRAVEL POLICY (V2 Sprint 3) ─────────────────────────

model TravelPolicy {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id])
  name                   String
  description            String?
  isDefault              Boolean      @default(false)
  isActive               Boolean      @default(true)
  maxFlightBudget        Decimal?     @db.Decimal(10,2)
  maxHotelBudgetPerNight Decimal?     @db.Decimal(10,2)
  maxDailyAllowance      Decimal?     @db.Decimal(10,2)
  currency               String       @default("XOF")
  allowedFlightClass     String?      // "ECONOMY" | "BUSINESS" | "FIRST"
  maxAdvanceBookingDays  Int?
  requiresApproval       Boolean      @default(true)
  approvalThreshold      Decimal?     @db.Decimal(10,2)
  allowedDestinations    String[]     @default([])
  restrictedDestinations String[]     @default([])
  appliesToDepartments   String[]     @default([])
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  travelRequests TravelRequest[]

  @@map("travel_policies")
}

// ─── GROUP TRAVEL (V2 Sprint 3) ──────────────────────────

enum GroupTravelStatus {
  DRAFT
  OPEN
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ParticipantStatus {
  INVITED
  CONFIRMED
  DECLINED
  CANCELLED
}

model GroupTravel {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  leaderId        String
  leader          User              @relation("GroupTravelLeader", fields: [leaderId], references: [id])
  title           String
  description     String?
  destination     String
  departureDate   DateTime
  returnDate      DateTime
  estimatedCost   Decimal?          @db.Decimal(10,2)
  maxParticipants Int?
  status          GroupTravelStatus @default(DRAFT)
  currency        String            @default("XOF")
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  participants   GroupTravelParticipant[]
  travelRequests TravelRequest[]

  @@map("group_travels")
}

model GroupTravelParticipant {
  id            String            @id @default(cuid())
  groupTravelId String
  groupTravel   GroupTravel       @relation(fields: [groupTravelId], references: [id])
  userId        String
  user          User              @relation("GroupTravelParticipant", fields: [userId], references: [id])
  status        ParticipantStatus @default(INVITED)
  note          String?
  invitedAt     DateTime          @default(now())
  respondedAt   DateTime?

  @@unique([groupTravelId, userId])
  @@map("group_travel_participants")
}

// ─── TRAVEL REWARD (V2 Sprint 3) ─────────────────────────

enum RewardStatus {
  EARNED
  REDEEMED
  EXPIRED
  CANCELLED
}

model TravelReward {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  userId          String
  user            User          @relation("TravelRewardUser", fields: [userId], references: [id])
  travelRequestId String?       @unique
  travelRequest   TravelRequest? @relation("TravelRequestReward", fields: [travelRequestId], references: [id])
  points          Int
  reason          String        // "ECONOMY_BOOKING" | "EARLY_BOOKING" | "MANUAL"
  status          RewardStatus  @default(EARNED)
  estimatedCost   Decimal?      @db.Decimal(10,2)
  actualCost      Decimal?      @db.Decimal(10,2)
  savedAmount     Decimal?      @db.Decimal(10,2)
  currency        String        @default("XOF")
  expiresAt       DateTime?
  redeemedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@map("travel_rewards")
}

// ─── OCR SCAN (V2 Sprint 3) ──────────────────────────────

enum OcrStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model OcrScan {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("OcrScanUser", fields: [userId], references: [id])
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  fileUrl         String
  rawText         String?
  extractedData   Json?         // { amount, date, vendor, currency }
  status          OcrStatus     @default(PENDING)
  errorMessage    String?
  expenseReportId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("ocr_scans")
}

// ─── EVENT PHOTO (V2 Sprint 4) ────────────────────────────

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

model EventPhoto {
  id             String      @id @default(cuid())
  eventId        String
  event          Event       @relation(fields: [eventId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  uploadedBy     String
  uploader       User        @relation("EventPhotoUploader", fields: [uploadedBy], references: [id])
  url            String
  caption        String?
  status         PhotoStatus @default(PENDING)
  createdAt      DateTime    @default(now())

  likes          EventPhotoLike[]

  @@map("event_photos")
}

model EventPhotoLike {
  id        String     @id @default(cuid())
  photoId   String
  photo     EventPhoto @relation(fields: [photoId], references: [id])
  userId    String
  user      User       @relation("EventPhotoLiker", fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([photoId, userId])
  @@map("event_photo_likes")
}

// ─── FAQ ENTRY (V2 Sprint 4) ──────────────────────────────

enum FaqStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FaqEntry {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  question       String
  answer         String
  category       String?
  order          Int       @default(0)
  status         FaqStatus @default(DRAFT)
  createdById    String
  createdBy      User      @relation("FaqEntryAuthor", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  votes          FaqVote[]

  @@map("faq_entries")
}

model FaqVote {
  id         String   @id @default(cuid())
  faqEntryId String
  faqEntry   FaqEntry @relation(fields: [faqEntryId], references: [id])
  userId     String
  user       User     @relation("FaqVoter", fields: [userId], references: [id])
  helpful    Boolean
  createdAt  DateTime @default(now())

  @@unique([faqEntryId, userId])
  @@map("faq_votes")
}