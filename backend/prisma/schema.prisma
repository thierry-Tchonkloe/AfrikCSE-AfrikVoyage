generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String     @id @default(uuid())
  name          String
  email         String?    @unique
  slug          String     @unique
  status        OrgStatus  @default(PENDING)
  hasVoyage     Boolean    @default(false)
  hasCSE        Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now())
  address       String?
  businessEmail String?
  city          String?
  country       String?
  industry      String?
  phone         String?
  plan          Plan       @default(STARTER)
  postalCode    String?
  region        String?
  rejectedAt    DateTime?
  rejectionNote String?
  size          String?
  validatedAt   DateTime?
  validatedById String?
  auditLogs     AuditLog[]
  users         User[]
  invitationTokens InvitationToken[]

  @@map("organizations")
}

model User {
  id                     String       @id @default(uuid())
  email                  String       @unique
  password               String
  role                   Role         @default(EMPLOYE)
  firstName              String
  lastName               String
  isActive               Boolean      @default(true)
  refreshToken           String?
  lastLoginAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @default(now())
  organizationId         String
  avatar                 String?
  costCenter             String?
  department             String?
  emailVerified          Boolean      @default(false)
  emailVerifiedAt        DateTime?
  jobTitle               String?
  managerId              String?
  phone                  String?
  profileCompleted       Boolean      @default(false)
  resetPasswordExpiresAt DateTime?
  resetPasswordToken     String?
  auditLogs              AuditLog[]
  manager                User?        @relation("UserManager", fields: [managerId], references: [id])
  managedUsers           User[]       @relation("UserManager")
  organization           Organization @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entity         String
  entityId       String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum Plan {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum Role {
  ADMIN
  MANAGER
  RH
  FINANCE
  EMPLOYE
  SUPER_ADMIN
}


// ─── PLATFORM SETTINGS ─────────────────────────────────

model PlatformSettings {
  id                    String   @id @default("singleton") // Un seul enregistrement

  logoUrl               String?
  primaryColor          String   @default("#0f766e")
  secondaryColor        String   @default("#f59e0b")
  darkModeEnabled       Boolean  @default(true)

  manualValidation      Boolean  @default(true)
  autoRegistration      Boolean  @default(false)

  defaultHasCSE         Boolean  @default(false)
  defaultHasVoyage      Boolean  @default(false)

  notifyOnValidation    Boolean  @default(true)
  notifyOnRejection     Boolean  @default(true)
  notifyWelcome         Boolean  @default(false)

  updatedAt             DateTime @updatedAt

  @@map("platform_settings")
}

// ─── PLAN ──────────────────────────────────────────────

model PlanConfig {
  id          String   @id @default(cuid())
  name        String   @unique // "STARTER", "BUSINESS", "ENTERPRISE"
  label       String            // Nom affiché
  price       String            // "Gratuit", "Sur devis", etc.
  maxUsers    Int?              // null = illimité
  hasVoyage   Boolean  @default(false)
  hasCSE      Boolean  @default(false)
  features    String[]          // Liste des fonctionnalités
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plan_configs")
}

// ─── INVITATION TOKEN ──────────────────────────────────// Token d'activation envoyé à l'admin après validation

model InvitationToken {
  id             String    @id @default(cuid())
  token          String    @unique // Token hashé
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  usedAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@map("invitation_tokens")
}


// ─── Enum ─────────────────────────────────────────────────────────────────────

enum ContactStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─── Model ────────────────────────────────────────────────────────────────────

model ContactRequest {
  id               Int           @id @default(autoincrement())
  fullName         String
  company          String
  email            String
  phone            String        @default("")
  companySize      String        @default("")
  message          String
  acceptMarketing  Boolean       @default(false)
  status           ContactStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("contact_requests")
}