// ─── PARTNER (V2 Sprint 1) ─────────────────────────────

enum PartnerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PartnerScope {
  CSE
  VOYAGE
  BOTH
}

enum OfferType {
  VOUCHER
  BOOKING
  DISCOUNT_CODE
}

model Partner {
  id              String        @id @default(cuid())
  name            String
  sector          String
  logoUrl         String?
  contactEmail    String?
  websiteUrl      String?
  notes           String?
  status          PartnerStatus @default(DRAFT)
  scopeType       PartnerScope  @default(CSE)
  apiEnabled      Boolean       @default(false)
  apiBaseUrl      String?
  apiKeyEncrypted String?
  apiFormat       String?
  syncFrequencyH  Int           @default(24)
  isGlobal        Boolean       @default(true)
  organizationIds String[]
  partnerToken    String?       @unique
  warningCount    Int           @default(0)
  flaggedAt       DateTime?
  // ─── V3 Sprint 1 ────────────────────────────────────
