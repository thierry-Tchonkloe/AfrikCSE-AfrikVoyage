{
  "name": "backend-afrikcse-and-afrikvoyage",
  "version": "1.0.0",
  "description": "Backend AfrikCSE & AfrikVoyage - Node.js/Express/Prisma/PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate --early-access",
    "prisma:migrate": "prisma migrate dev --early-access",
    "prisma:deploy": "prisma migrate deploy --early-access",
    "prisma:studio": "prisma studio --early-access",
    "prisma:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "afrikvoyage",
    "afrikcse",
    "backend",
    "cms",
    "nodejs",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  }
}
