# ─── Production Environment (Vercel) ───────────────────────────────────────
# Ajoute ces variables dans les "Environment Variables" de Vercel

# 🔑 Backend API URL - Replace XXX par ton URL Render
NEXT_PUBLIC_API_URL=https://XXX.onrender.com/api

# 🔑 JWT Secret (doit matcher la secret du backend pour vérifier tokens côté client)
JWT_SECRET=your_strong_random_secret_here

# 🔑 App info
NEXT_PUBLIC_APP_NAME="AfrikCSE & AfrikVoyage"
